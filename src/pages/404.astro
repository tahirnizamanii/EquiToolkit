---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="Page Not Found | EquiToolkit">
  <div class="page-wrap">
    <div class="hero-icon"><i class="fa-solid fa-horse"></i></div>
    <h1>Whoa there, partner!</h1>
    <p>The page you're looking for has wandered off. Let's get you back to the barn.</p>
    <div class="actions">
      <a href="/" class="btn btn-primary"><i class="fa-solid fa-home"></i> Back to Home</a>
      <a href="/search" class="btn btn-outline"><i class="fa-solid fa-magnifying-glass"></i> Search Tools</a>
    </div>
  </div>
</MainLayout>

<style>
  .page-wrap { max-width: 600px; margin: 0 auto; padding: 5rem 2rem; text-align: center; }
  .hero-icon { font-size: 5rem; color: var(--primary); margin-bottom: 1.5rem; }
  h1 { font-size: 2.2rem; font-weight: 800; color: var(--text); margin-bottom: 0.5rem; }
  p { color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }
  .actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.7rem 1.8rem; border-radius: 50px; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: 0.2s; }
  .btn-primary { background: var(--primary); color: white; box-shadow: 0 4px 14px rgba(46,92,62,0.2); }
  .btn-primary:hover { background: #1e4532; transform: translateY(-1px); }
  .btn-outline { background: white; color: var(--primary); border: 2px solid var(--primary); }
  .btn-outline:hover { background: var(--primary-light); }
</style>