---
import MainLayout from '@/layouts/MainLayout.astro';
import { PRINTABLES } from '@/data/printables';

export function getStaticPaths() {
  return PRINTABLES.map(p => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const printable = PRINTABLES.find(p => p.id === slug);
---

<MainLayout title={printable ? `${printable.title} | EquiToolkit Printables` : 'Printable Not Found'} description={printable?.description || ''}>
  {!printable ? (
    <div class="not-found">
      <h1>Printable Not Found</h1>
      <p>Sorry, that printable template doesn't exist. <a href="/printables">Browse all printables</a>.</p>
    </div>
  ) : (
    <div class="page-wrap">
      <!-- Your existing printable detail template here -->
      <p>Printable content for: {printable.title}</p>
    </div>
  )}
</MainLayout>