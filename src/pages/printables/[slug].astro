---
import MainLayout from '@/layouts/MainLayout.astro';
import { PRINTABLES } from '@/data/printables';

export function getStaticPaths() {
  return PRINTABLES.map(p => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const printable = PRINTABLES.find(p => p.id === slug);

if (!printable) {
  return <MainLayout title="Not Found"><p>Printable not found.</p></MainLayout>;
}
---

<MainLayout title={`${printable.title} | EquiToolkit Printables`} description={printable.description}>
  <div class="page-wrap no-print-meta">
    <nav class="breadcrumbs no-print">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <a href="/printables">Printables</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>{printable.title}</span>
    </nav>

    <div class="print-bar no-print">
      <a href="/printables" class="btn btn-ghost"><i class="fa-solid fa-arrow-left"></i> Back</a>
      <button class="btn btn-primary" onclick="window.print()"><i class="fa-solid fa-print"></i> Print This Sheet</button>
    </div>

    <div class="printable-sheet">
      <div class="sheet-header">
        <div>
          <span class="category-tag">{printable.category}</span>
          <h1>{printable.title}</h1>
          <p>{printable.description}</p>
        </div>
        <div class="brand">
          <i class="fa-solid fa-horse"></i>
          <span>EquiToolkit.com</span>
        </div>
      </div>

      <div class="sheet-body">
        {printable.sections.map(sec => (
          <section class="form-section">
            <h2>{sec.title}</h2>

            {sec.items && (
              <div class="checklist">
                {sec.items.map(item => (
                  <label class="check-item">
                    <input type="checkbox" />
                    <span>{item}</span>
                  </label>
                ))}
              </div>
            )}

            {sec.fields && (
              <div class="fields-grid">
                {sec.fields.map(f => {
                  if (f.type === 'table' && f.columns && f.rows) {
                    return (
                      <div class="table-wrapper">
                        <table>
                          <thead>
                            <tr>
                              {f.columns.map(col => <th>{col}</th>)}
                            </tr>
                          </thead>
                          <tbody>
                            {f.rows.map(row => (
                              <tr>
                                {f.columns!.map(col => <td>{row[col] || ''}</td>)}
                              </tr>
                            ))}
                            {Array.from({ length: 3 }).map(() => (
                              <tr>
                                {f.columns!.map(() => <td></td>)}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    );
                  }
                  return (
                    <div class="field">
                      <label>{f.label}</label>
                      <input type="text" placeholder={f.placeholder || '_________________'} />
                    </div>
                  );
                })}
              </div>
            )}
          </section>
        ))}
      </div>

      <div class="sheet-footer">
        <p>Instructions: {printable.instructions}</p>
        <p>Date Printed: <span id="print-date"></span></p>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  document.getElementById('print-date')!.textContent = new Date().toLocaleDateString();
</script>

<style>
  .page-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }
  .breadcrumbs {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .print-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.4rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: 0.2s;
    cursor: pointer;
  }
  .btn-ghost {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--bg); }
  .btn-primary {
    background: var(--primary);
    color: white;
    border: none;
  }
  .btn-primary:hover { background: #1e4532; }

  .printable-sheet {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    box-shadow: var(--shadow-sm);
    page-break-inside: avoid;
  }
  .sheet-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 2px solid var(--border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  .category-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary);
    background: var(--primary-light);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 0.5rem;
  }
  .sheet-header h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text);
  }
  .sheet-header p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--primary);
    font-size: 1rem;
  }
  .brand i { font-size: 1.5rem; color: var(--accent); }

  .form-section {
    margin-bottom: 2.5rem;
  }
  .form-section h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .checklist {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 0.5rem;
  }
  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.3rem 0;
  }
  .check-item input { margin-top: 0.2rem; accent-color: var(--primary); }
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .field input {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    background: transparent;
  }
  .table-wrapper {
    grid-column: span 2;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  th {
    text-align: left;
    background: var(--bg);
    padding: 0.5rem;
    border: 1px solid var(--border);
    font-weight: 700;
    color: var(--text-muted);
  }
  td {
    padding: 0.5rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    height: 1.8rem;
  }
  .sheet-footer {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media print {
    .no-print, .no-print-meta .breadcrumbs, .print-bar { display: none; }
    body { background: white; }
    .printable-sheet { box-shadow: none; border: none; padding: 0; }
  }
</style>