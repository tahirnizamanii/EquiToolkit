---
import MainLayout from '@/layouts/MainLayout.astro';
import { FEED_DATABASE } from '@/data/feed';

const categories = ['All', 'Hay', 'Grass', 'Grain', 'Supplement', 'Mineral', 'Electrolyte'];
---

<MainLayout title="Equine Feed & Forage Encyclopedia | EquiToolkit" description="Explore different types of hay, pasture grasses, energy grains, supplements, and minerals to construct balanced dietary rations.">
  <div class="page-wrap">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>Feed Database</span>
    </nav>

    <header class="page-hero">
      <div class="hero-icon"><i class="fa-solid fa-wheat-awn"></i></div>
      <h1>Equine Feed & Forage Encyclopedia</h1>
      <p>Explore different types of hay, pasture grasses, energy grains, supplements, and minerals.</p>
    </header>

    <!-- Controls -->
    <div class="controls">
      <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="feed-search" placeholder="Search feed ingredients..." class="search-input" />
      </div>
      <div class="filter-tabs" id="cat-tabs">
        {categories.map(cat => (
          <button class="filter-tab" data-cat={cat} class:list={[{ active: cat === 'All' }]}>
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Feed Grid -->
    <div class="feed-grid" id="feed-grid">
      {FEED_DATABASE.map(item => (
        <div class="feed-card" data-category={item.category} data-name={item.name.toLowerCase()}>
          <div class="card-header">
            <h3>{item.name}</h3>
            <span class="category-tag">{item.category}</span>
          </div>
          <div class="card-body">
            <div class="info-row">
              <strong>Nutritional Matrix</strong>
              <span>{item.nutritionalValue}</span>
            </div>
            <div class="info-row">
              <strong>Suitable For</strong>
              <span>{item.suitableFor}</span>
            </div>
            <div class="pros-cons">
              <div>
                <h4><i class="fa-solid fa-circle-check"></i> Pros</h4>
                <ul>
                  {item.pros.map((p, i) => <li key={i}>{p}</li>)}
                </ul>
              </div>
              <div>
                <h4><i class="fa-solid fa-circle-xmark"></i> Cons</h4>
                <ul>
                  {item.cons.length > 0
                    ? item.cons.map((c, i) => <li key={i}>{c}</li>)
                    : <li class="none">None identified</li>
                  }
                </ul>
              </div>
            </div>
            <div class="recommendations">
              <strong><i class="fa-solid fa-lightbulb"></i> Feeding Instructions</strong>
              <p>{item.recommendations}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="no-results" class="empty-state hidden">
      <i class="fa-solid fa-circle-exclamation"></i>
      <p>No feed items match your search or filter.</p>
    </div>
  </div>
</MainLayout>

<script>
  const searchInput = document.getElementById('feed-search');
  const tabButtons = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.feed-card');
  const noResults = document.getElementById('no-results');
  let activeCat = 'All';
  let query = '';

  function filter() {
    let count = 0;
    cards.forEach(card => {
      const cat = card.dataset.category;
      const name = card.dataset.name || '';
      const matchCat = activeCat === 'All' || cat === activeCat;
      const matchSearch = name.includes(query);
      if (matchCat && matchSearch) {
        card.classList.remove('hidden');
        count++;
      } else {
        card.classList.add('hidden');
      }
    });
    noResults.classList.toggle('hidden', count > 0);
  }

  searchInput?.addEventListener('input', (e) => {
    query = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filter();
  });

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      tabButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.dataset.cat || 'All';
      filter();
    });
  });
</script>

<style>
  .page-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .breadcrumbs { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.5rem; }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .page-hero { text-align: center; margin-bottom: 2rem; }
  .hero-icon { font-size: 3rem; color: var(--primary); margin-bottom: 1rem; }
  .page-hero h1 { font-size: 2rem; font-weight: 800; color: var(--text); }
  .page-hero p { color: var(--text-muted); }

  .controls { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .search-box { position: relative; flex: 1; min-width: 250px; }
  .search-box i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
  .search-input { width: 100%; padding: 0.6rem 1rem 0.6rem 2.5rem; border: 1px solid var(--border); border-radius: 50px; font-size: 0.9rem; background: white; transition: border-color 0.2s; }
  .search-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(46,92,62,0.1); }
  .filter-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .filter-tab { background: white; border: 1px solid var(--border); color: var(--text-muted); padding: 0.5rem 1.2rem; border-radius: 50px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: 0.2s; }
  .filter-tab.active { background: var(--primary); border-color: var(--primary); color: white; }

  .feed-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 1.5rem; }
  .feed-card { background: white; border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); transition: 0.2s; display: flex; flex-direction: column; }
  .feed-card:hover { box-shadow: var(--shadow-lg); border-color: var(--accent); }
  .feed-card.hidden { display: none; }
  .card-header { display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 1.5rem; border-bottom: 1px solid var(--border); }
  .card-header h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); }
  .category-tag { font-size: 0.7rem; font-weight: 600; color: var(--primary); background: var(--primary-light); padding: 0.2rem 0.7rem; border-radius: 20px; }
  .card-body { padding: 1.2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; flex: 1; }
  .info-row { display: flex; flex-direction: column; gap: 0.2rem; }
  .info-row strong { font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; }
  .info-row span { font-size: 0.9rem; color: var(--text); }

  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .pros-cons h4 { font-size: 0.8rem; margin-bottom: 0.3rem; display: flex; align-items: center; gap: 0.3rem; }
  .pros-cons h4 i { font-size: 0.8rem; }
  .pros-cons h4 i.fa-circle-check { color: #2ecc71; }
  .pros-cons h4 i.fa-circle-xmark { color: #e74c3c; }
  .pros-cons ul { list-style: none; padding: 0; }
  .pros-cons li { font-size: 0.8rem; color: var(--text-muted); padding: 0.2rem 0; }
  .pros-cons li.none { font-style: italic; }

  .recommendations { background: var(--bg); border-radius: var(--radius-sm); padding: 1rem; }
  .recommendations strong { display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: var(--text); margin-bottom: 0.3rem; }
  .recommendations p { font-size: 0.8rem; color: var(--text-muted); margin: 0; line-height: 1.5; }

  .empty-state { text-align: center; padding: 3rem; color: var(--text-muted); background: white; border-radius: var(--radius); border: 1px solid var(--border); }
  .hidden { display: none; }
</style>