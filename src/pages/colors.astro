---
import MainLayout from '@/layouts/MainLayout.astro';
import { COAT_COLORS } from '@/data/colors';
---

<MainLayout title="Equine Coat Color Encyclopedia | EquiToolkit" description="Discover genetic profiles, locus structures, physical descriptions, and breeding tips for 12 beautiful coat colors.">
  <div class="page-wrap">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>Coat Colors</span>
    </nav>

    <header class="page-hero">
      <div class="hero-icon"><i class="fa-solid fa-palette"></i></div>
      <h1>Equine Coat Color Encyclopedia</h1>
      <p>Discover genetic profiles, locus structures, physical descriptions, and breeding tips for 12 beautiful coat colors.</p>
    </header>

    <div class="colors-grid">
      {COAT_COLORS.map(color => (
        <article class="color-card">
          <div class="color-header">
            <h2>{color.name}</h2>
            <span class="genotype-badge">{color.id.toUpperCase()}</span>
          </div>
          <p class="color-desc">{color.description}</p>

          <div class="color-details">
            <div class="detail-box">
              <h3><i class="fa-solid fa-dna"></i> Genetic Locus</h3>
              <p>{color.genetics}</p>
            </div>
            <div class="detail-box">
              <h3><i class="fa-solid fa-eye"></i> Visual Characteristics</h3>
              <p>{color.characteristics}</p>
            </div>
          </div>

          {color.faqs && color.faqs.length > 0 && (
            <div class="faq-box">
              <h3><i class="fa-solid fa-circle-question"></i> Common Questions</h3>
              {color.faqs.map(faq => (
                <details>
                  <summary>{faq.question}</summary>
                  <p>{faq.answer}</p>
                </details>
              ))}
            </div>
          )}

          <div class="linking-note">
            <p>{color.linkingNote}</p>
            <a href="/foal-color-predictor" class="btn btn-primary">
              <i class="fa-solid fa-dna"></i> Launch Foal Color Predictor
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</MainLayout>

<style>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .breadcrumbs {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .page-hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero-icon {
    font-size: 3rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .page-hero h1 { font-size: 2rem; font-weight: 800; color: var(--text); margin-bottom: 0.5rem; }
  .page-hero p { color: var(--text-muted); }

  .colors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 2rem;
  }
  .color-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
  }
  .color-card:hover {
    box-shadow: var(--shadow-lg);
  }
  .color-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  .color-header h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
  }
  .genotype-badge {
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--primary-light);
    color: var(--primary);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-family: monospace;
  }
  .color-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .detail-box {
    background: var(--bg);
    border-radius: var(--radius-sm);
    padding: 1rem;
    margin-bottom: 1rem;
  }
  .detail-box h3 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .detail-box h3 i { color: var(--primary); font-size: 1rem; }
  .detail-box p {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: monospace;
    line-height: 1.4;
  }
  .faq-box {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-top: 1rem;
  }
  .faq-box h3 {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
  }
  .faq-box h3 i { color: var(--accent); }
  details {
    margin-bottom: 0.5rem;
  }
  summary {
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
    color: var(--text);
    padding: 0.3rem 0;
  }
  details p {
    font-size: 0.8rem;
    color: var(--text-muted);
    padding-left: 1rem;
    line-height: 1.5;
  }
  .linking-note {
    background: var(--primary-light);
    border: 1px solid rgba(46,92,62,0.15);
    border-radius: var(--radius-sm);
    padding: 1rem;
    text-align: center;
    margin-top: auto;
  }
  .linking-note p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.4rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: 0.2s;
  }
  .btn-primary {
    background: var(--primary);
    color: white;
    box-shadow: 0 4px 14px rgba(46,92,62,0.2);
  }
  .btn-primary:hover { background: #1e4532; transform: translateY(-1px); }
</style>