---
import MainLayout from '@/layouts/MainLayout.astro';
import { BREEDS } from '@/data/breeds';

// Map breed sizes for filter
function getBreedSizeCategory(b: typeof BREEDS[number]): string {
  const h = b.heightRange.toLowerCase();
  if (h.includes('under') || h.includes('pony') || b.id.includes('pony') || b.id.includes('miniature') || b.id.includes('falabella')) {
    return 'Pony / Miniature';
  }
  if (b.weightRange.includes('1,600') || b.weightRange.includes('1,800') || b.weightRange.includes('2,200') || b.weightRange.includes('2,400')) {
    return 'Draft Horse';
  }
  if (b.overview.toLowerCase().includes('warmblood') || b.uses.includes('Dressage') || b.uses.includes('Show Jumping')) {
    return 'Sport Warmblood';
  }
  return 'Light Riding / Stock';
}
---

<MainLayout title="Horse Breed Encyclopedia & Care Database | EquiToolkit" description="Explore physical standards, health parameters, dietary suggestions, and history for over 50 popular horse breeds.">
  <div class="page-wrap">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>Breeds</span>
    </nav>

    <header class="page-hero">
      <div class="hero-icon"><i class="fa-solid fa-horse"></i></div>
      <h1>Horse Breed Care Database</h1>
      <p>Explore physical standards, health parameters, dietary suggestions, and history for over 50 popular horse breeds.</p>
    </header>

    <!-- Controls -->
    <div class="controls">
      <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="breed-search" placeholder="Search breeds (e.g., Arabian, Clydesdale)..." class="search-input" />
      </div>
      <div class="filter-tabs" id="size-tabs">
        <button class="filter-tab active" data-size="All">All</button>
        <button class="filter-tab" data-size="Light Riding / Stock">Light Riding</button>
        <button class="filter-tab" data-size="Sport Warmblood">Warmblood</button>
        <button class="filter-tab" data-size="Draft Horse">Draft</button>
        <button class="filter-tab" data-size="Pony / Miniature">Pony</button>
      </div>
    </div>

    <!-- Breed Grid -->
    <div class="breeds-grid" id="breeds-grid">
      {BREEDS.map(breed => (
        <a href={`/breeds/${breed.id}`} class="breed-card" data-size={getBreedSizeCategory(breed)} data-name={breed.name.toLowerCase()}>
          <div class="breed-meta">
            <span class="breed-size">{getBreedSizeCategory(breed)}</span>
            <i class="fa-solid fa-chevron-right"></i>
          </div>
          <h3>{breed.name}</h3>
          <p>{breed.overview.slice(0, 120)}…</p>
          <div class="breed-stats">
            <span>{breed.heightRange.split(' (')[0]}</span>
            <span>{breed.weightRange.split(' lbs')[0]} lbs</span>
          </div>
        </a>
      ))}
    </div>

    <div id="no-results" class="empty-state hidden">
      <i class="fa-solid fa-circle-exclamation"></i>
      <p>No breeds match your search or filter.</p>
    </div>
  </div>
</MainLayout>

<script>
  const searchInput = document.getElementById('breed-search');
  const sizeTabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.breed-card');
  const noResults = document.getElementById('no-results');
  let activeSize = 'All';
  let query = '';

  function filter() {
    let count = 0;
    cards.forEach(card => {
      const size = card.dataset.size;
      const name = card.dataset.name || '';
      const matchSize = activeSize === 'All' || size === activeSize;
      const matchSearch = name.includes(query);
      if (matchSize && matchSearch) {
        card.classList.remove('hidden');
        count++;
      } else {
        card.classList.add('hidden');
      }
    });
    noResults.classList.toggle('hidden', count > 0);
  }

  searchInput?.addEventListener('input', (e) => {
    query = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filter();
  });

  sizeTabs.forEach(btn => {
    btn.addEventListener('click', () => {
      sizeTabs.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeSize = btn.dataset.size || 'All';
      filter();
    });
  });
</script>

<style>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .breadcrumbs {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .page-hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero-icon {
    font-size: 3rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .page-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .page-hero p {
    color: var(--text-muted);
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .search-box {
    position: relative;
    flex: 1;
    min-width: 250px;
  }
  .search-box i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
  }
  .search-input {
    width: 100%;
    padding: 0.6rem 1rem 0.6rem 2.5rem;
    border: 1px solid var(--border);
    border-radius: 50px;
    font-size: 0.9rem;
    background: white;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(46,92,62,0.1);
  }
  .filter-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .filter-tab {
    background: white;
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
  }
  .filter-tab.active {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }

  .breeds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .breed-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.8rem;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: 0.2s;
    display: flex;
    flex-direction: column;
  }
  .breed-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .breed-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .breed-size {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary);
    background: var(--primary-light);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
  }
  .breed-meta i {
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: transform 0.2s;
  }
  .breed-card:hover .breed-meta i {
    transform: translateX(3px);
    color: var(--primary);
  }
  .breed-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .breed-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    flex: 1;
    margin-bottom: 1rem;
  }
  .breed-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    padding-top: 0.8rem;
    font-weight: 500;
  }
  .hidden { display: none; }
  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
</style>