---
import MainLayout from '@/layouts/MainLayout.astro';
import { PRINTABLES } from '@/data/printables';
---

<MainLayout title="Printable Stable Log Books & Checklists | EquiToolkit" description="Equine show checklists, farrier ledgers, stable feed signs, and health record cards optimized for home printers.">
  <div class="page-wrap">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>Printable Resources</span>
    </nav>

    <header class="page-hero">
      <div class="hero-icon"><i class="fa-solid fa-file-pdf"></i></div>
      <h1>Printable Stable Templates</h1>
      <p>Show checklists, farrier ledgers, feed charts, and health record cards — ready to print.</p>
    </header>

    <div class="grid">
      {PRINTABLES.map(p => (
        <a href={`/printables/${p.id}`} class="card">
          <div class="card-meta">
            <span class="tag">{p.category}</span>
            <i class="fa-solid fa-chevron-right"></i>
          </div>
          <h3>{p.title}</h3>
          <p>{p.description}</p>
          <span class="cta-text">Open & Print →</span>
        </a>
      ))}
    </div>
  </div>
</MainLayout>

<style>
  .page-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .breadcrumbs { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.5rem; }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .page-hero { text-align: center; margin-bottom: 3rem; }
  .hero-icon { font-size: 3rem; color: var(--primary); margin-bottom: 1rem; }
  .page-hero h1 { font-size: 2rem; font-weight: 800; color: var(--text); }
  .page-hero p { color: var(--text-muted); }

  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .card { background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.8rem; box-shadow: var(--shadow-sm); text-decoration: none; color: inherit; transition: 0.2s; display: flex; flex-direction: column; }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--accent); }
  .card-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }
  .tag { font-size: 0.7rem; font-weight: 600; color: var(--primary); background: var(--primary-light); padding: 0.2rem 0.7rem; border-radius: 20px; }
  .card-meta i { color: var(--text-muted); font-size: 0.8rem; transition: transform 0.2s; }
  .card:hover .card-meta i { transform: translateX(3px); color: var(--primary); }
  .card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .card p { font-size: 0.85rem; color: var(--text-muted); flex: 1; margin-bottom: 1rem; }
  .cta-text { font-weight: 600; color: var(--primary); font-size: 0.85rem; display: flex; align-items: center; gap: 0.3rem; }
</style>