---
import MainLayout from '@/layouts/MainLayout.astro';
import { ARTICLES } from '@/data/articles';

const categories = ['All', 'Health & Care', 'Management', 'Training & Prep'];
---

<MainLayout title="Equestrian Guides & Veterinary Reference Articles | EquiToolkit" description="Read our research‑driven articles covering horse blanketing charts, body condition scoring zones, and genetic base outcomes.">
  <div class="page-wrap">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span>Articles</span>
    </nav>

    <header class="page-hero">
      <div class="hero-icon"><i class="fa-solid fa-book-open"></i></div>
      <h1>Educational Equine Articles</h1>
      <p>Read expert guides on horse nutrition, pregnancy stages, strategic deworming, winter blanketing rules, and saddle fitting.</p>
    </header>

    <!-- Search & Filter -->
    <div class="controls">
      <div class="search-box">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" id="article-search" placeholder="Search articles..." class="search-input" />
      </div>
      <div class="filter-tabs" id="cat-tabs">
        {categories.map(cat => (
          <button class={`filter-tab ${cat === 'All' ? 'active' : ''}`} data-cat={cat}>
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Articles grid -->
    <div class="articles-grid" id="articles-grid">
      {ARTICLES.map(article => (
        <a href={`/articles/${article.slug}`} class="article-card" data-category={article.category} data-name={article.title.toLowerCase()} data-summary={article.summary.toLowerCase()}>
          <div class="article-meta">
            <span class="article-tag">{article.category}</span>
            <span class="article-readtime"><i class="fa-solid fa-clock"></i> {article.readTime}</span>
          </div>
          <h3>{article.title}</h3>
          <p>{article.summary}</p>
          <span class="article-cta">Read Article <i class="fa-solid fa-arrow-right"></i></span>
        </a>
      ))}
    </div>

    <div id="no-results" class="empty-state hidden">
      <i class="fa-solid fa-circle-exclamation"></i>
      <p>No articles match your search. Try a different keyword or reset the filter.</p>
      <button id="reset-search-btn" class="btn btn-outline"><i class="fa-solid fa-rotate-right"></i> Reset</button>
    </div>
  </div>
</MainLayout>

<script>
  const searchInput = document.getElementById('article-search');
  const tabButtons = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.article-card');
  const noResults = document.getElementById('no-results');
  let activeCat = 'All';
  let query = '';

  function filter() {
    let count = 0;
    cards.forEach(card => {
      const cat = card.dataset.category;
      const name = card.dataset.name || '';
      const summary = card.dataset.summary || '';
      const matchCat = activeCat === 'All' || cat === activeCat;
      const matchSearch = name.includes(query) || summary.includes(query);
      if (matchCat && matchSearch) {
        card.classList.remove('hidden');
        count++;
      } else {
        card.classList.add('hidden');
      }
    });
    noResults.classList.toggle('hidden', count > 0);
  }

  searchInput?.addEventListener('input', (e) => {
    query = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filter();
  });

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      tabButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.dataset.cat || 'All';
      filter();
    });
  });

  document.getElementById('reset-search-btn')?.addEventListener('click', () => {
    if (searchInput) (searchInput as HTMLInputElement).value = '';
    query = '';
    const allTab = document.querySelector('[data-cat="All"]') as HTMLElement;
    allTab?.click();
  });
</script>

<style>
  .page-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .breadcrumbs { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.5rem; }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--primary); }
  .breadcrumbs i { font-size: 0.7rem; }

  .page-hero { text-align: center; margin-bottom: 3rem; }
  .hero-icon { font-size: 3rem; color: var(--primary); margin-bottom: 1rem; }
  .page-hero h1 { font-size: 2rem; font-weight: 800; color: var(--text); margin-bottom: 0.5rem; }
  .page-hero p { color: var(--text-muted); }

  .controls { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .search-box { position: relative; flex: 1; min-width: 250px; }
  .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
  .search-input { width: 100%; padding: 0.6rem 1rem 0.6rem 2.5rem; border: 1px solid var(--border); border-radius: 50px; font-size: 0.9rem; background: white; transition: border-color 0.2s; }
  .search-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(46,92,62,0.1); }
  .filter-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .filter-tab { background: white; border: 1px solid var(--border); color: var(--text-muted); padding: 0.5rem 1.2rem; border-radius: 50px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: 0.2s; }
  .filter-tab.active { background: var(--primary); border-color: var(--primary); color: white; }

  .articles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .article-card { background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.8rem; box-shadow: var(--shadow-sm); text-decoration: none; color: inherit; transition: 0.2s; display: flex; flex-direction: column; }
  .article-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--accent); }
  .article-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; font-size: 0.8rem; }
  .article-tag { background: var(--primary-light); color: var(--primary); font-weight: 600; padding: 0.2rem 0.7rem; border-radius: 20px; font-size: 0.7rem; }
  .article-readtime { color: var(--text-muted); display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; }
  .article-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .article-card p { font-size: 0.85rem; color: var(--text-muted); flex: 1; margin-bottom: 1rem; }
  .article-cta { font-weight: 600; color: var(--primary); display: flex; align-items: center; gap: 0.3rem; font-size: 0.85rem; }

  .empty-state { text-align: center; padding: 3rem; color: var(--text-muted); background: white; border-radius: var(--radius); border: 1px solid var(--border); }
  .hidden { display: none; }
  .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1.2rem; border-radius: 50px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: 0.2s; border: none; }
  .btn-outline { background: transparent; color: var(--primary); border: 1px solid var(--primary); }
  .btn-outline:hover { background: var(--primary-light); }
</style>