---
<button
  id="scroll-to-top"
  class="fixed bottom-6 right-6 z-50 bg-primary hover:bg-primary/95 text-white w-10 h-10 rounded-full shadow-lg flex items-center justify-center transition-all hover:scale-105 cursor-pointer no-print hidden"
  title="Scroll back to top"
  aria-label="Scroll back to top"
>
  <i class="fa-solid fa-arrow-up"></i>
</button>

<script>
  const scrollBtn = document.getElementById('scroll-to-top');
  if (scrollBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        scrollBtn.classList.remove('hidden');
      } else {
        scrollBtn.classList.add('hidden');
      }
    });

    scrollBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
