---
// src/components/Footer.astro
---

<footer class="site-footer">
  <div class="footer-grid">
    <!-- Brand Column -->
    <div class="footer-col">
      <div class="brand-row">
        <i class="fa-solid fa-horse brand-icon"></i>
        <span class="brand-name">EquiToolkit</span>
      </div>
      <p class="brand-desc">
        The premier online destination for 100% free, browser‑native equine calculators, health estimators, and equestrian planning tools. No registrations, no advertisements, no tracking.
      </p>
    </div>

    <!-- Popular Tools Column -->
    <div class="footer-col">
      <h4 class="footer-heading">Popular Tools</h4>
      <ul class="footer-links">
        <li>
          <a href="/horse-weight-calculator" class="footer-link">
            <i class="fa-solid fa-scale-balanced"></i> Weight Calculator
          </a>
        </li>
        <li>
          <a href="/blanketing-guide" class="footer-link">
            <i class="fa-solid fa-temperature-three-quarters"></i> Blanketing Chart
          </a>
        </li>
        <li>
          <a href="/foal-color-predictor" class="footer-link">
            <i class="fa-solid fa-dna"></i> Foal Color Genetics
          </a>
        </li>
        <li>
          <a href="/riding-log" class="footer-link">
            <i class="fa-solid fa-book-open"></i> Riding Log & Journal
          </a>
        </li>
      </ul>
    </div>

    <!-- Equine Knowledge Hub Column -->
    <div class="footer-col">
      <h4 class="footer-heading">Equine Knowledge Hub</h4>
      <ul class="footer-links">
        <li>
          <a href="/breeds" class="footer-link">
            <i class="fa-solid fa-horse-head"></i> Breed Care Database
          </a>
        </li>
        <li>
          <a href="/colors" class="footer-link">
            <i class="fa-solid fa-palette"></i> Coat Color Encyclopedia
          </a>
        </li>
        <li>
          <a href="/reference-tables" class="footer-link">
            <i class="fa-solid fa-table"></i> Reference Tables
          </a>
        </li>
        <li>
          <a href="/health-library" class="footer-link">
            <i class="fa-solid fa-notes-medical"></i> Horse Health Library
          </a>
        </li>
        <li>
          <a href="/feed-database" class="footer-link">
            <i class="fa-solid fa-wheat-awn"></i> Feed & Forage Database
          </a>
        </li>
        <li>
          <a href="/equipment-guides" class="footer-link">
            <i class="fa-solid fa-toolbox"></i> Tack & Equipment Guides
          </a>
        </li>
      </ul>
    </div>

    <!-- Stable & Breeding Column -->
    <div class="footer-col">
      <h4 class="footer-heading">Stable & Breeding</h4>
      <ul class="footer-links">
        <li>
          <a href="/stable-hub" class="footer-link">
            <i class="fa-solid fa-home"></i> Stable Operations Hub
          </a>
        </li>
        <li>
          <a href="/breed-comparison" class="footer-link">
            <i class="fa-solid fa-chart-simple"></i> Breed Comparison Tool
          </a>
        </li>
        <li>
          <a href="/growth-charts" class="footer-link">
            <i class="fa-solid fa-chart-line"></i> Interactive Growth Charts
          </a>
        </li>
        <li>
          <a href="/timelines" class="footer-link">
            <i class="fa-solid fa-hourglass-half"></i> Husbandry Timelines
          </a>
        </li>
        <li>
          <a href="/seasonal-care" class="footer-link">
            <i class="fa-solid fa-calendar-days"></i> Seasonal Care Guides
          </a>
        </li>
        <li>
          <a href="/trust" class="footer-link">
            <i class="fa-solid fa-shield-haltered"></i> Editorial & Trust Policy
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <p class="copyright">
      © 2026 EquiToolkit. Made with <i class="fa-solid fa-heart heart-icon"></i> for the worldwide equestrian community.
    </p>
    <nav class="legal-links">
      <a href="/privacy" class="legal-link">Privacy Policy</a>
      <span class="divider">·</span>
      <a href="/terms" class="legal-link">Terms of Use</a>
      <span class="divider">·</span>
      <a href="/disclaimer" class="legal-link disclaimer-link">Medical Disclaimer</a>
      <span class="divider">·</span>
      <a href="/sitemap" class="legal-link">XML Sitemap</a>
    </nav>
  </div>
</footer>

<style>
  /* Footer container */
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 3rem 2rem 1.5rem;
    margin-top: 4rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Grid layout */
  .footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Brand */
  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
  }
  .brand-icon {
    font-size: 1.6rem;
    color: var(--accent);
  }
  .brand-name {
    font-weight: 800;
    font-size: 1.3rem;
    color: var(--primary);
  }
  .brand-desc {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  /* Columns */
  .footer-heading {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--primary);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.85rem;
    transition: color 0.2s;
  }
  .footer-link i {
    width: 1.2rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--primary);
  }
  .footer-link:hover {
    color: var(--primary);
  }

  /* Bottom Bar */
  .footer-bottom {
    max-width: 1200px;
    margin: 1.5rem auto 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
  }
  .copyright {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .heart-icon {
    color: #e74c3c;
    font-size: 0.8rem;
  }
  .legal-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 500;
  }
  .legal-link {
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .legal-link:hover {
    color: var(--primary);
  }
  .disclaimer-link {
    color: #c0392b;  /* red tone to emphasize medical disclaimer */
  }
  .disclaimer-link:hover {
    color: #a93226;
  }
  .divider {
    color: var(--border);
  }
</style>